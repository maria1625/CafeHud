# Base de datos de test
URL=mongodb://localhost:27017/cafe-spa-test
MONGODB_URI=mongodb://localhost:27017/cafe-spa-test

# Servidor
PORT=3001
NODE_ENV=test

# JWT
SECRET=test_jwt_secret_key_for_testing_only_not_for_production
JWT_SECRET=test_jwt_secret_key_for_testing_only_not_for_production
JWT_EXPIRES_IN=1h

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (más permisivo para tests)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logs
LOG_LEVEL=error
